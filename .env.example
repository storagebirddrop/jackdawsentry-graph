# Jackdaw Sentry Graph environment example
#
# Copy this file to `.env`, replace the placeholder secrets, and then run:
#   docker compose -f docker-compose.graph.yml up -d --build
#
# Never commit a real `.env`.

# Core secrets
NEO4J_PASSWORD=replace-with-a-long-random-string
POSTGRES_PASSWORD=replace-with-a-long-random-string
REDIS_PASSWORD=replace-with-a-long-random-string
API_SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-long-random-string
ENCRYPTION_KEY=replace-with-a-long-random-string

# Graph Postgres runtime
POSTGRES_DB=jackdawsentry_graph
POSTGRES_USER=jackdawsentry_user

# Graph Redis runtime
REDIS_DB=0

# Application behavior
LOG_LEVEL=INFO
JWT_EXPIRE_MINUTES=30
TRUST_PROXY_HEADERS=false
EXPOSE_API_DOCS=false
ENABLE_LEGACY_GRAPH_ENDPOINTS=false
EXPOSE_METRICS=false
DUAL_WRITE_RAW_EVENT_STORE=false
AUTO_BACKFILL_RAW_EVENT_STORE=false

# Optional RPC overrides
BITCOIN_RPC_URL=https://bitcoin-rpc.publicnode.com
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com
SOLANA_RPC_URL=https://solana-rpc.publicnode.com

# Published ports from docker-compose.graph.yml
#   graph UI:      http://localhost:8081
#   Neo4j browser: http://localhost:7475
#   Neo4j bolt:    bolt://localhost:7688
#   Postgres:      localhost:5433
#   Redis:         localhost:6380
