# Jackdaw Sentry Graph environment example
#
# Copy this file to `.env`, replace the placeholder secrets, and then run:
#   docker compose -f docker-compose.graph.yml up -d --build
#
# Never commit a real `.env`.

# Core secrets
NEO4J_PASSWORD=replace-with-a-long-random-string
POSTGRES_PASSWORD=replace-with-a-long-random-string
REDIS_PASSWORD=replace-with-a-long-random-string
API_SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-long-random-string
ENCRYPTION_KEY=replace-with-a-long-random-string

# Graph Postgres runtime
POSTGRES_DB=jackdawsentry_graph
POSTGRES_USER=jackdawsentry_user

# Graph Redis runtime
REDIS_DB=0

# Application behavior
LOG_LEVEL=INFO
JWT_EXPIRE_MINUTES=30
TRUST_PROXY_HEADERS=false
EXPOSE_API_DOCS=false
ENABLE_LEGACY_GRAPH_ENDPOINTS=false
EXPOSE_METRICS=false
RATE_LIMIT_ENABLED=true
DUAL_WRITE_RAW_EVENT_STORE=true
AUTO_BACKFILL_RAW_EVENT_STORE=true
BACKFILL_INTERVAL_SECONDS=30
BACKFILL_BLOCK_BATCH_SIZE=2
BACKFILL_CHAINS_PER_CYCLE=4
BACKFILL_BLOCK_TIMEOUT_SECONDS=120

# Third-party API keys
ETHERSCAN_API_KEY=

# RPC / REST endpoints
# Public free-tier defaults are provided where available.
# Replace with your own endpoints for production or high-volume use.
BITCOIN_RPC_URL=https://bitcoin-rpc.publicnode.com
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
BSC_RPC_URL=https://bsc-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com
BASE_RPC_URL=https://base-rpc.publicnode.com
AVALANCHE_RPC_URL=https://avalanche-c-chain-rpc.publicnode.com
OPTIMISM_RPC_URL=https://optimism-rpc.publicnode.com
SOLANA_RPC_URL=https://solana-rpc.publicnode.com
SUI_RPC_URL=https://sui-rpc.publicnode.com
TRON_RPC_URL=https://tron-rpc.publicnode.com
XRPL_RPC_URL=https://xrplcluster.com
STARKNET_RPC_URL=https://starknet-rpc.publicnode.com
COSMOS_REST_URL=https://cosmos-rest.publicnode.com
INJECTIVE_REST_URL=https://lcd.injective.network

# Optional development settings
GRAPH_AUTH_DISABLED=false
AUTH_DISABLE_CONFIRM=false
#   graph UI:      http://localhost:8081
#   Neo4j browser: http://localhost:7475
#   Neo4j bolt:    bolt://localhost:7688
#   Postgres:      localhost:5433
#   Redis:         localhost:6380

# Optional ingestion overlay:
#   docker compose \
#     -f docker-compose.graph.yml \
#     -f docker-compose.graph.ingest.yml \
#     up -d --build
#
# The overlay starts a dedicated `graph-ingest` sidecar for live collector
# and backfill work, keeping the request-serving graph-api lean.
# The sidecar-specific GRAPH_INGEST_* overrides below take precedence for
# that container.
#
# Optional ingest-sidecar overrides:
# GRAPH_INGEST_DUAL_WRITE_RAW_EVENT_STORE=true
# GRAPH_INGEST_AUTO_BACKFILL_RAW_EVENT_STORE=true
# GRAPH_INGEST_BACKFILL_INTERVAL_SECONDS=30
# GRAPH_INGEST_BACKFILL_BLOCK_BATCH_SIZE=2
# GRAPH_INGEST_BACKFILL_CHAINS_PER_CYCLE=4
# GRAPH_INGEST_BACKFILL_BLOCK_TIMEOUT_SECONDS=120
